# Server port (default: 3000)
PORT=3000

# A long random string for signing session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Optional password protection.
# Leave empty for open-access (local dev only).
# Generate a bcrypt hash with:
#   cd self-hosted && npm install && npm run hash-password yourpassword
PASSWORD_HASH=

# Display title injected into the tool header
TOOL_TITLE=Sponsor Deliverables Tracker

# Branding colours (hex)
PRIMARY_COLOR=#6366f1
ACCENT_COLOR=#f59e0b
